<sessions>
	<remmina%>
		extends_base=<sessions.base%>
	</remmina%>
	<remmina0>
		<name_localized>
			displayname[en_us]=<Remmina>
		</name_localized>
		<icon>
			value=</services/remmina/.icons/app.svg>
		</icon>
		<type>
			displayname[en_us]=<Misc>
		</type>
	</remmina0>
	node_action=<wm_postsetup>
</sessions>
